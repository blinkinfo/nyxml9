# ============================================================
# REQUIRED — must be set for the bot to work
# ============================================================

# Polymarket account credentials
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# Telegram bot credentials (from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ============================================================
# OPTIONAL — sensible defaults if left unset
# ============================================================

# Polymarket CLOB signature type (1 = EOA, 2 = proxy wallet)
POLYMARKET_SIGNATURE_TYPE=2

# Fixed USDC amount per trade (used when TRADE_MODE=fixed)
TRADE_AMOUNT_USDC=1.0

# Trade sizing mode: "fixed" (flat USDC) or "pct" (% of bankroll)
TRADE_MODE=fixed

# Percentage of bankroll to risk per trade (used when TRADE_MODE=pct)
TRADE_PCT=5.0

# FOK order settings — how the bot handles Fill-or-Kill retries

# Max retry attempts for FOK orders
FOK_MAX_RETRIES=3

# Initial delay between retries (seconds)
FOK_RETRY_DELAY_BASE=2.0

# Max delay between retries (seconds, with backoff)
FOK_RETRY_DELAY_MAX=5.0

# Stop retrying FOK orders this many seconds before the slot closes
FOK_SLOT_CUTOFF_SECONDS=30

# Database file path (defaults to autopoly.db in the working directory)
DB_PATH=autopoly.db

# Active strategy label (shown in /status and logs)
# Use "pattern" for rule-based strategy, "ml" for ML inference strategy
STRATEGY_NAME=pattern

# UTC hours when trading is blocked (0-23, comma-separated).
# Default blocks 03:00--03:59 and 17:00--17:59 UTC.
BLOCKED_TRADE_HOURS_UTC=3,17

# Polygon RPC endpoint (public fallback works; use Alchemy/Infura for production)
POLYGON_RPC_URL=https://polygon-rpc.com

# Auto-redeem scheduler interval in minutes
AUTO_REDEEM_INTERVAL_MINUTES=5


# ============================================================
# DEMO MODE — managed via /settings in Telegram, not env vars
# ============================================================
# DEMO_TRADE_ENABLED  -->  DB setting (default: false)
# DEMO_BANKROLL_USDC  -->  DB setting (default: 1000.00)
# No env var needed; toggle from the bot UI.


# ============================================================
# ML STRATEGY — required when STRATEGY_NAME=ml
# ============================================================

# Strategy selector — set to "ml" to enable ML inference mode
# STRATEGY_NAME=ml

# ML signal confidence threshold (0.50 – 0.95).
# The model fires a trade only when P(UP) >= threshold (UP signal)
# or P(DOWN) = 1 - P(UP) >= threshold (DOWN signal).
# Lower = more trades, higher = more selective.
# Can also be adjusted live via /set_threshold in Telegram.
ML_THRESHOLD=0.535
